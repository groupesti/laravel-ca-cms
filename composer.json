{
    "name": "groupesti/laravel-ca-cms",
    "description": "CMS/PKCS#7 cryptographic message syntax for Laravel CA (RFC 5652)",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "groupesti/laravel-ca": "^0.1",
        "groupesti/laravel-ca-crt": "^0.1",
        "groupesti/laravel-ca-key": "^0.1",
        "phpseclib/phpseclib": "^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "CA\\Cms\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CA\\Cms\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CA\\Cms\\CmsServiceProvider"
            ],
            "aliases": {
                "CaCms": "CA\\Cms\\Facades\\CaCms"
            }
        }
    }
}
